{
  "name": "smart-agriculture-backend",
  "version": "1.0.0",
  "description": "Smart Agriculture Assistant Backend with Marathi Support",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --config nodemon.json server.js",
    "dev:verbose": "nodemon --config nodemon.json --verbose server.js",
    "client": "cd client && npm start",
    "install-client": "cd client && npm install",
    "build-client": "cd client && npm run build",
    "dev:all": "concurrently \"npm run dev\" \"npm run client\" --names \"BACKEND,FRONTEND\" --prefix-colors \"bgBlue.bold,bgMagenta.bold\"",
    "test:disease": "node test-disease-detection.js",
    "init-db": "node init-db-native.js"
  },
  "keywords": [
    "agriculture",
    "marathi",
    "farming",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.2",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "form-data": "^4.0.0",
    "mongoose": "^9.1.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}